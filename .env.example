# Copy to .env and fill in. Never commit the real .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Gmail (App Password — NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_TO=your-address@gmail.com

# Captcha solver (optional — only needed if you enable auto-apply)
# Provider one of: twocaptcha, capsolver
CAPTCHA_PROVIDER=twocaptcha
CAPTCHA_API_KEY=

# IMAP (defaults to Gmail; same address + app password as SMTP above)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Outbound application email. Set ALL FOUR to enable live sends; leave
# any blank and the email channel falls back to dry-run (writes
# application.eml to the per-job output dir, no SMTP call).
# Use a business mailbox, NOT your Gmail — the Gmail account is reserved
# for the digest. Common providers: IONOS, Fastmail, Zoho, Postmark.
TRUENORTH_SMTP_HOST=          # e.g. smtp.ionos.de
TRUENORTH_SMTP_PORT=587       # 587 = STARTTLS (recommended), 465 = SSL
TRUENORTH_SMTP_USER=          # e.g. you@your-domain.com
TRUENORTH_SMTP_PASS=          # the mailbox password
