# Copy to .env and fill in. Never commit the real .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Gmail (App Password — NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=hilbertp@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_TO=hilbertp@gmail.com

# Captcha solver (optional — only needed if you enable auto-apply)
# Provider one of: twocaptcha, capsolver
CAPTCHA_PROVIDER=twocaptcha
CAPTCHA_API_KEY=

# IMAP (defaults to Gmail; same address + app password as SMTP above)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
