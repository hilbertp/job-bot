<!doctype html>
<html><head><meta charset="utf-8">
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
         max-width: 760px; margin: 1.5rem auto; padding: 0 1rem; color: #111; line-height: 1.5; }
  h1 { font-size: 1.4rem; }
  h2 { font-size: 1.1rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.2rem; margin-top: 2rem; }
  .job { border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.9rem 1rem; margin-bottom: 1rem; }
  .job-head { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; }
  .meta { color: #6b7280; font-size: 0.9rem; }
  .score { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.95rem;
           background: #ecfdf5; color: #047857; font-weight: 700; white-space: nowrap; }
  .status-submitted { color: #047857; font-weight: 600; }
  .status-needs_review { color: #b45309; font-weight: 600; }
  .status-failed { color: #b91c1c; font-weight: 600; }
  .status-dry_run { color: #6b7280; font-weight: 600; }
  details { margin-top: 0.5rem; }
  pre { background: #f9fafb; padding: 0.6rem; border-radius: 6px; overflow-x: auto; font-size: 0.85rem; }
  .errors { background: #fef2f2; border: 1px solid #fecaca; padding: 0.8rem 1rem; border-radius: 8px; }
  /* PRD §7.7 FR-APP-01 channel pills, right next to the match score. */
  .channel { display: inline-block; padding: 3px 10px; border-radius: 999px;
             font-size: 0.85rem; font-weight: 600; white-space: nowrap;
             margin-left: 0.4rem; }
  .channel-email    { background: #eff6ff; color: #1d4ed8; }
  .channel-form     { background: #ecfdf5; color: #047857; }
  .channel-external { background: #f5f3ff; color: #6d28d9; }
  .channel-manual   { background: #f3f4f6; color: #6b7280; }
  .source-summary { background: #f9fafb; border: 1px solid #e5e7eb;
                    padding: 0.6rem 0.9rem; border-radius: 8px;
                    font-size: 0.9rem; margin-bottom: 1rem; }
  .source-summary ul { margin: 0.3rem 0 0; padding-left: 1.2rem; }
  .source-summary li { color: #374151; }
</style></head>
<body>
<h1>jobbot · {{ n }} new match{{ 'es' if n != 1 else '' }}</h1>
<p class="meta">Run started {{ run_started.strftime('%Y-%m-%d %H:%M %Z') }}</p>

{% macro channel_pill(m) -%}
{%- set ch = m.apply_channel or 'manual' -%}
{%- if ch == 'email' -%}
  <span class="channel channel-email" title="{{ m.apply_email }}">📧 email</span>
{%- elif ch == 'form' -%}
  <span class="channel channel-form" title="{{ m.apply_url }}">🔗 {{ m.apply_channel_ats_name or 'form' }}</span>
{%- elif ch == 'external' -%}
  <span class="channel channel-external" title="{{ m.apply_url }}">🌐 external</span>
{%- else -%}
  <span class="channel channel-manual">✋ manual</span>
{%- endif -%}
{%- endmacro %}

{% if matches %}
{% set generated = matches | selectattr('output_dir') | list %}
{% set manual = matches | rejectattr('output_dir') | list %}

{# PRD §7.7 FR-APP-01: per-source breakdown of how applications would route, so
   the user can see at a glance which sources have automatable channels. #}
{% set source_breakdown = namespace(rows={}) %}
{% for m in matches %}
  {%- set src = m.job.source or 'unknown' -%}
  {%- if src not in source_breakdown.rows -%}
    {%- set _ = source_breakdown.rows.update({src: {'total': 0, 'email': 0, 'form': 0, 'external': 0, 'manual': 0}}) -%}
  {%- endif -%}
  {%- set bucket = source_breakdown.rows[src] -%}
  {%- set _ = bucket.update({'total': bucket.total + 1}) -%}
  {%- set ch = m.apply_channel or 'manual' -%}
  {%- set _ = bucket.update({ch: bucket[ch] + 1}) -%}
{% endfor %}
{% if source_breakdown.rows %}
<div class="source-summary">
  <strong>Per-source apply channels</strong>
  <ul>
    {% for src, bucket in source_breakdown.rows.items() %}
    <li>{{ src }}: {{ bucket.total }} scored
        {%- if bucket.email %} · {{ bucket.email }} via email{% endif -%}
        {%- if bucket.form %} · {{ bucket.form }} via form{% endif -%}
        {%- if bucket.external %} · {{ bucket.external }} external{% endif -%}
        {%- if bucket.manual %} · {{ bucket.manual }} manual{% endif -%}
    </li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<h2>Top matches (CV + cover letter generated)</h2>
{% if generated %}
{% for m in generated %}
<div class="job">
  <div class="job-head">
    <div><strong>{{ m.job.title }}</strong>, {{ m.job.company }}
         {% if m.job.location %}· {{ m.job.location }}{% endif %}</div>
    <span class="score">Score {{ m.score }}</span>{{ channel_pill(m) }}
  </div>
  <div class="meta">{{ m.job.source }} · <a href="{{ m.job.url }}">view posting</a>
       {% if m.apply_status %} · status:
         <span class="status-{{ m.apply_status }}">{{ m.apply_status }}</span>
       {% endif %}
  </div>
  <div style="margin-top: 0.4rem">{{ m.reason }}</div>
  {% if m.cover_letter_html %}
  <details><summary>Cover letter</summary>
    {{ m.cover_letter_html|safe }}
  </details>
  {% endif %}
  {% if m.output_dir %}
  <div class="meta" style="margin-top: 0.4rem">files: <code>{{ m.output_dir }}</code></div>
  {% endif %}
</div>
{% endfor %}
{% else %}
<p>No postings reached the document generation score cutoff.</p>
{% endif %}

<h2>Other postings (manual review)</h2>
{% if manual %}
{% for m in manual %}
<div class="job">
  <div class="job-head">
    <div><strong>{{ m.job.title }}</strong>, {{ m.job.company }}
         {% if m.job.location %}· {{ m.job.location }}{% endif %}</div>
    <span class="score">Score {{ m.score }}</span>{{ channel_pill(m) }}
  </div>
  <div class="meta">{{ m.job.source }} · <a href="{{ m.job.url }}">view posting</a></div>
  <div style="margin-top: 0.4rem">{{ m.reason }}</div>
</div>
{% endfor %}
{% else %}
<p>No additional postings for manual review.</p>
{% endif %}
{% else %}
<p>No matches found for this run.</p>
{% endif %}

{% if cannot_score %}
<h2>Cannot score ({{ cannot_score|length }})</h2>
<p class="meta">These postings could not be scored, a hard precondition for scoring was not met. Reason shown verbatim; no numeric score is implied.</p>
{% for c in cannot_score %}
<div class="job">
  <div class="job-head">
    <div><strong>{{ c.job.title }}</strong>, {{ c.job.company }}
         {% if c.job.location %}· {{ c.job.location }}{% endif %}</div>
    <span class="score" style="background:#fef2f2;color:#b91c1c;">{{ c.status }}</span>
  </div>
  <div class="meta">{{ c.job.source }} · <a href="{{ c.job.url }}">view posting</a></div>
  <div style="margin-top: 0.4rem"><code>{{ c.reason }}</code></div>
</div>
{% endfor %}
{% endif %}

{% if errors %}
<h2>Errors</h2>
<div class="errors">
  <ul>
  {% for e in errors %}
    <li><strong>{{ e.source }}</strong>: {{ e.error }}</li>
  {% endfor %}
  </ul>
</div>
{% endif %}

</body></html>
